[Unit]
Description=CamillaDSP
After=default.target
StartLimitIntervalSec=10
StartLimitBurst=10

[Service]
Type=simple
User=car
WorkingDirectory=~
TimeoutStartSec=10
ExecStartPre=/bin/sleep 2
ExecStart=camilladsp -o camilladsp/camilladsp.log -p 1234 -l error camilladsp/configs/default.yml
Restart=always
RestartSec=1
StandardOutput=journal
StandardError=journal
SyslogIdentifier=camilladsp
Nice= -40

[Install]
WantedBy=default.target
